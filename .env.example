# Copy to .env — docker compose reads these to configure the api service.
# At minimum, set a strong ADMIN_TOKEN before deploying.

OLLAMA_URL=http://192.168.1.182:11434
OLLAMA_MODEL=gemma4:12b
OLLAMA_KEEP_ALIVE=30m
OLLAMA_NUM_PREDICT=512
ADMIN_TOKEN=change-me-to-a-long-random-string

SOFT_LIMIT=8
MAX_MSG_LEN=2000
HISTORY_TURNS=12
RATE_LIMIT_WINDOW_MS=600000
RATE_LIMIT_MAX=40

# Telegram notifications for new contact/chat leads (optional).
# Get a token from @BotFather; get your chat id from @userinfobot.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
