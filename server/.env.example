# Ollama connection (the project host must be able to reach this address)
OLLAMA_URL=http://192.168.1.182:11434
OLLAMA_MODEL=gemma4:12b

# Admin endpoints (/api/admin/*) require this token. Set a long random value.
ADMIN_TOKEN=change-me-to-a-long-random-string

# Chat behaviour
SOFT_LIMIT=8           # user messages per session before asking for contact (chat continues)
MAX_MSG_LEN=2000       # max characters per message
HISTORY_TURNS=12       # how many past turns to send to the model

# Per-IP rate limiting
RATE_LIMIT_WINDOW_MS=600000
RATE_LIMIT_MAX=40

# Server
PORT=3000
DB_PATH=/app/data/chat.db
